<Window x:Class="TowerDefense.StageIntroPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stage Intro"
        Width="840"
        Height="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#F8FAFC"
            BorderBrush="#1E293B"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding StageTitle}"
                               Foreground="#0F172A"
                               FontSize="30"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding ChapterText}"
                               Foreground="#475569"
                               FontSize="14"
                               Margin="0,6,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding AlertText}"
                           Foreground="#B91C1C"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </Grid>

            <Border Grid.Row="1"
                    Background="#E0F2FE"
                    BorderBrush="#7DD3FC"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,18,0,18">
                <TextBlock Text="{Binding BannerText}"
                           Foreground="#075985"
                           FontSize="13"
                           TextWrapping="Wrap" />
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.15*" />
                </Grid.ColumnDefinitions>

                <TabControl Background="Transparent"
                            BorderThickness="0">
                    <TabItem Header="신규">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding NewEnemies}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SelectEnemyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="0"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                HorizontalContentAlignment="Stretch">
                                            <Border Background="#FFFFFF"
                                                    BorderBrush="#CBD5E1"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="12"
                                                    Margin="0,0,10,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="58" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Image Source="{Binding PreviewImage}"
                                                           Width="48"
                                                           Height="48"
                                                           Stretch="Uniform" />
                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#0F172A" />
                                                        <TextBlock Text="{Binding EnemyId}"
                                                                   FontSize="12"
                                                                   Foreground="#64748B"
                                                                   Margin="0,3,0,0" />
                                                        <TextBlock Text="{Binding HpPercent, StringFormat=HP {0:0}%}"
                                                                   FontSize="12"
                                                                   Foreground="#15803D"
                                                                   Margin="0,8,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="재등장">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ReturningEnemies}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SelectEnemyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="0"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                HorizontalContentAlignment="Stretch">
                                            <Border Background="#FFFFFF"
                                                    BorderBrush="#CBD5E1"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="12"
                                                    Margin="0,0,10,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="58" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Image Source="{Binding PreviewImage}"
                                                           Width="48"
                                                           Height="48"
                                                           Stretch="Uniform" />
                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#0F172A" />
                                                        <TextBlock Text="{Binding EnemyId}"
                                                                   FontSize="12"
                                                                   Foreground="#64748B"
                                                                   Margin="0,3,0,0" />
                                                        <TextBlock Text="{Binding HpPercent, StringFormat=HP {0:0}%}"
                                                                   FontSize="12"
                                                                   Foreground="#15803D"
                                                                   Margin="0,8,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <Border Grid.Column="1"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="16"
                        Margin="18,0,0,0">
                    <StackPanel>
                        <Image Source="{Binding SelectedEnemy.PreviewImage}"
                               Width="112"
                               Height="112"
                               Stretch="Uniform"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,14" />
                        <TextBlock Text="{Binding SelectedEnemy.DisplayName}"
                                   Foreground="#0F172A"
                                   FontSize="20"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedEnemy.EnemyId}"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding SelectedEnemy.HpPercent, StringFormat=HP {0:0}%}"
                                   Foreground="#15803D"
                                   FontWeight="SemiBold"
                                   Margin="0,16,0,10" />
                        <ItemsControl ItemsSource="{Binding SelectedEnemy.Abilities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Foreground="#334155"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <DockPanel Grid.Row="3" Margin="0,20,0,0">
                <Button DockPanel.Dock="Left"
                        Content="항상 건너뛰기"
                        Command="{Binding SkipAlwaysCommand}"
                        Width="132"
                        Height="38"
                        Background="#E2E8F0"
                        Foreground="#334155" />
                <Button DockPanel.Dock="Right"
                        Content="스테이지 시작"
                        Command="{Binding StartCommand}"
                        Width="160"
                        Height="42"
                        Background="#5CAD5C"
                        Foreground="#07120A"
                        FontWeight="Bold" />
            </DockPanel>
        </Grid>
    </Border>
</Window>
