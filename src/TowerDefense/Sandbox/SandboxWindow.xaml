<Window x:Class="TowerDefense.Sandbox.SandboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tower Defense Sandbox"
        Width="980"
        Height="680"
        MinWidth="880"
        MinHeight="600"
        Background="#111820">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button Content="기본 웨이브"
                        Width="112"
                        Height="36"
                        Click="StartWave_Click"
                        Background="#5CAD5C"
                        Foreground="#07120A"
                        FontWeight="Bold" />
                <Button Content="분열 테스트"
                        Width="112"
                        Height="36"
                        Margin="8,0,0,0"
                        Click="StartSplitWave_Click"
                        Background="#F97316"
                        Foreground="#1C0A03"
                        FontWeight="Bold" />
                <Button Content="리셋"
                        Width="80"
                        Height="36"
                        Margin="8,0,0,0"
                        Click="Reset_Click"
                        Background="#E2E8F0"
                        Foreground="#1E293B" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="타워디펜스 테스트"
                           Foreground="#F8FAFC"
                           FontSize="26"
                           FontWeight="Bold" />
                <TextBlock Text="초록 타워는 피해, 파란 타워는 슬로우를 적용합니다."
                           Foreground="#93A4B8"
                           FontSize="13"
                           Margin="0,5,0,0" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                BorderBrush="#263646"
                BorderThickness="1"
                Background="#17212B"
                CornerRadius="8"
                Padding="10">
            <Canvas x:Name="GameCanvas"
                    Background="#0F1720"
                    ClipToBounds="True" />
        </Border>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="HudText"
                       Foreground="#D7E1EC"
                       FontSize="14"
                       FontWeight="SemiBold" />
            <TextBlock x:Name="StatusText"
                       DockPanel.Dock="Right"
                       Foreground="#93A4B8"
                       FontSize="13" />
        </DockPanel>
    </Grid>
</Window>
