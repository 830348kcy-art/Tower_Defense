<Window x:Class="TowerDefense.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tower Defense"
        Width="960"
        Height="640"
        MinWidth="760"
        MinHeight="520"
        Background="#101418">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Tower Defense"
                       Foreground="#F5F7FA"
                       FontSize="34"
                       FontWeight="Bold" />
            <TextBlock Text="{Binding StageSummary}"
                       Foreground="#9FB2C8"
                       FontSize="16"
                       Margin="0,8,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,28,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border BorderBrush="#2B3642"
                    BorderThickness="1"
                    Background="#151B22"
                    CornerRadius="8"
                    Padding="20">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="New Enemies"
                               Foreground="#F5F7FA"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16" />
                    <ItemsControl ItemsSource="{Binding Intro.NewEnemies}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#314457"
                                        BorderThickness="1"
                                        Background="#1A232C"
                                        CornerRadius="6"
                                        Padding="14"
                                        Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="#F5F7FA"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding EnemyId}"
                                                   Foreground="#7F95AA"
                                                   FontSize="12"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding HpPercent, StringFormat=HP {0:0}%}"
                                                   Foreground="#B6D77A"
                                                   FontSize="13"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="#2B3642"
                    BorderThickness="1"
                    Background="#151B22"
                    CornerRadius="8"
                    Padding="20"
                    Margin="18,0,0,0">
                <StackPanel>
                    <TextBlock Text="Status"
                               Foreground="#F5F7FA"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#C9D5E3"
                               FontSize="14"
                               TextWrapping="Wrap"
                               Margin="0,14,0,22" />
                    <Button Content="Start Stage"
                            Command="{Binding StartStageCommand}"
                            Height="44"
                            Background="#5CAD5C"
                            Foreground="#081008"
                            FontWeight="Bold" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="MVP: core rules, stage intro, enemy previews"
                   Foreground="#6F8397"
                   FontSize="12" />
    </Grid>
</Window>
