<Page x:Class="KingdomRushClone.Views.TowerGuidePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="타워 도감" Background="#1B1F24">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 상단 헤더 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <Button Content="◀ 메인" Width="100" Height="36"
                    Click="OnBack" Background="#455A64" Foreground="White" BorderThickness="0"/>
            <TextBlock Text="타워 도감" FontSize="28" FontWeight="Bold"
                       Foreground="#FFD369" Margin="20,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="각 타워의 역할과 업그레이드 경로를 확인하세요"
                       Foreground="#AAAAAA" FontSize="14" Margin="20,0,0,0" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- 좌: 타워 목록 / 우: 상세 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 타워 목록 -->
            <Border Grid.Column="0" Background="#222831" CornerRadius="8" Margin="0,0,12,0" Padding="10">
                <StackPanel x:Name="TowerListPanel"/>
            </Border>

            <!-- 상세 패널 -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <Border Background="#222831" CornerRadius="8" Padding="24">
                    <StackPanel x:Name="DetailPanel"/>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
