<Page x:Class="KingdomRushClone.Views.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Main Menu" Background="#1B1F24">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="1" HorizontalAlignment="Center">
            <TextBlock Text="Team-Tower_Defense" FontSize="56" Foreground="#FFD369" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="WPF Tower Defense — Team Tower" FontSize="16" Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,0,0,40"/>
            <Button x:Name="BtnStart" Content="게임 시작" Width="280" Height="56" FontSize="22" Margin="0,8" Click="OnStart" Background="#2E7D32" Foreground="White" BorderThickness="0"/>
            <Button x:Name="BtnTech" Content="테크트리 (영구 강화)" Width="280" Height="48" FontSize="18" Margin="0,8" Click="OnTech" Background="#3F51B5" Foreground="White" BorderThickness="0"/>
            <Button x:Name="BtnGuide" Content="🏹 타워 도감" Width="280" Height="48" FontSize="18" Margin="0,8" Click="OnGuide" Background="#00695C" Foreground="White" BorderThickness="0"/>
            <Button x:Name="BtnHelp" Content="도움말" Width="280" Height="42" FontSize="16" Margin="0,8" Click="OnHelp" Background="#455A64" Foreground="White" BorderThickness="0"/>
            <Button x:Name="BtnExit" Content="종료" Width="280" Height="42" FontSize="16" Margin="0,8" Click="OnExit" Background="#B71C1C" Foreground="White" BorderThickness="0"/>
            <TextBlock x:Name="StatsText" Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,30,0,0" FontSize="14"/>
        </StackPanel>
    </Grid>
</Page>
